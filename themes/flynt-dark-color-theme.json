    "semanticTokenColors": {
        "namespace": { "foreground": "#B43C7C", "italic": true },
        "class": "#60A848",
        "class.declaration": "#60A848",
        "interface": { "foreground": "#93AE42", "italic": true },
        "enum": "#60A848",
        "struct": "#60A848",
        "typeParameter": "#60A848",
        "type": "#60A848",
        "function": "#C69F2A",
        "function.declaration": "#C69F2A",
        "method": "#C69F2A",
        "method.declaration": "#C69F2A",
        "decorator": "#BA6836",
        "macro": "#BA6836",
        "variable": "#D8CEBC",
        "variable.readonly": "#D8CEBC",
        "variable.defaultLibrary": "#C03054",
        "parameter": "#D8CEBC",
        "property": "#A89A88",
        "property.readonly": "#A89A88",
        "enumMember": "#D8CEBC",
        "keyword": "#79685A",
        "operator": "#C03054",
        "number": "#48A8A0",
        "string": "#427BAE",
        "regexp": "#603CB4",
        "comment": { "foreground": "#584F45", "italic": true },
        "selfKeyword": { "foreground": "#C03054", "italic": true },
        "lifetime": { "foreground": "#603CB4", "italic": true }
    },
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#584F45", "fontStyle": "italic" }
        },
        {
            "scope": "comment.error",
            "settings": { "foreground": "#C6372A", "fontStyle": "italic" }
        },
        {
            "scope": ["comment.todo", "comment.warning", "comment.warn"],
            "settings": { "foreground": "#BA6836", "fontStyle": "italic" }
        },
        {
            "scope": "string",
            "settings": { "foreground": "#427BAE" }
        },
        {
            "scope": "string.template",
            "settings": { "foreground": "#427BAE" }
        },
        {
            "scope": ["string.regexp", "constant.other.character-class.regexp"],
            "settings": { "foreground": "#603CB4" }
        },
        {
            "scope": ["constant.character.escape", "constant.character"],
            "settings": { "foreground": "#603CB4" }
        },
        {
            "scope": "constant.numeric",
            "settings": { "foreground": "#48A8A0" }
        },
        {
            "scope": "constant.language",
            "settings": { "foreground": "#48A8A0" }
        },
        {
            "scope": ["constant.other", "constant.other.color"],
            "settings": { "foreground": "#D8CEBC" }
        },
        {
            "scope": "keyword",
            "settings": { "foreground": "#79685A" }
        },
        {
            "scope": ["keyword.operator", "keyword.operator.type"],
            "settings": { "foreground": "#C03054" }
        },
        {
            "scope": ["storage.type", "storage.modifier"],
            "settings": { "foreground": "#79685A" }
        },
        {
            "scope": ["entity.name.function"],
            "settings": { "foreground": "#C69F2A" }
        },
        {
            "scope": ["entity.name.type", "entity.name.type.class", "entity.name.type.struct", "entity.name.type.enum"],
            "settings": { "foreground": "#60A848" }
        },
        {
            "scope": "entity.name.tag",
            "settings": { "foreground": "#93AE42" }
        },

{
    "name": "flynt",
    "displayName": "Flynt",
    "description": "Warm tones. Zero visual noise.",
    "version": "0.1.0",
    "publisher": "flynt-theme",
    "author": "Flynt Theme",
    "repository": {
        "url": "https://github.com/flynt-theme/flynt-vscode"
    },
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": ["Themes"],
    "keywords": ["theme", "dark", "light", "warm", "minimal"],
    "icon": "assets/icon.png",
    "galleryBanner": {
        "color": "#100E0C",
        "theme": "dark"
    },
    "contributes": {
        "themes": [
            {
                "label": "Flynt Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/flynt-dark-color-theme.json"
            },
            {
                "label": "Flynt Light",
                "uiTheme": "vs",
                "path": "./themes/flynt-light-color-theme.json"
            }
        ]
    }
}
